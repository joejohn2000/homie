  <diagram id="v2-data-flow" name="03 Matching and Messaging Flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="f-title" value="Homie V2 - Matching and Messaging Flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=28;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="560" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f-sub" value="Detailed end-to-end flow from discovery request to recommendation generation, match creation, conversation start, and notification fanout" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=15;fontColor=#6B7280;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1120" height="24" as="geometry" />
        </mxCell>
        <mxCell id="f-1" value="1. User requests recommendations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-2" value="2. API Gateway validates session and request context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="350" y="180" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-3" value="3. Recommendation service loads profile, filters, and candidate pool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="650" y="180" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-4" value="4. Search index returns geo-filtered and availability-filtered candidates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="980" y="180" width="290" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-5" value="5. Ranking engine scores lifestyle fit, budget fit, commute fit, and recency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1320" y="180" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-6" value="6. User likes a room / candidate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-7" value="7. Matching service records swipe action and evaluates mutual interest rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="380" y="380" width="310" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-8" value="8. Match state is created or updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="760" y="380" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-9" value="9. Conversation service provisions a thread when mutual interest exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1060" y="380" width="290" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-10" value="10. Notification service fan-outs push, email, and in-app alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1390" y="380" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f-11" value="11. Conversation thread stores messages, unread state, and moderation metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#111827;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="370" y="580" width="320" height="90" as="geometry" />
